---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import TagPill from "../../components/TagPill.astro";
import { formatDate, getTagSummaries, sortPostsByDate } from "../../lib/posts";

const posts = sortPostsByDate(await getCollection("posts"));
const topics = getTagSummaries(posts);
---

<BaseLayout title="主题" description="Waltz 的主题索引：按技术、经验、感想与灵感浏览文章。">
  <section class="section topics-hero">
    <div class="container workbench-grid">
      <div class="topics-copy">
        <p class="terminal-label">topics / signal map</p>
        <h1 class="section-title">主题索引</h1>
        <p>
          这些入口不是严格分类，更像思考留下的坐标。技术、经验、感想和灵感会在这里交叉发光。
        </p>
      </div>

      <aside class="topics-status surface" aria-label="主题索引统计">
        <p class="terminal-label">index stats</p>
        <div class="status-grid">
          <div>
            <strong>{topics.length}</strong>
            <span>topics</span>
          </div>
          <div>
            <strong>{posts.length}</strong>
            <span>articles</span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="terminal-label">topic board</p>
        <h2 class="section-title">选择一个信号</h2>
      </div>

      <div class="topic-grid">
        {topics.map((topic) => (
          <a class="topic-card" href={topic.href}>
            <div class="topic-card-head">
              <TagPill tag={topic.tag} count={topic.count} />
              <span>{formatDate(topic.latestDate)}</span>
            </div>
            <p>{topic.posts.slice(0, 2).map((post) => post.data.title).join(" / ")}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section topic-groups-section">
    <div class="container topic-groups">
      {topics.map((topic) => (
        <section class="topic-group" id={topic.slug}>
          <div class="topic-group-head">
            <div>
              <p class="terminal-label">topic / {topic.count} records</p>
              <h2>{topic.tag}</h2>
            </div>
            <a class="topic-more" href={topic.href}>进入主题</a>
          </div>
          <div class="article-list">
            {topic.posts.map((post) => <ArticleCard post={post} />)}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .topics-hero {
    border-bottom: 1px solid var(--line);
  }

  .topics-copy {
    grid-column: span 7;
  }

  .topics-copy p:last-child {
    max-width: 660px;
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .topics-status {
    grid-column: 8 / span 5;
    align-self: end;
    padding: 20px;
  }

  .status-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .status-grid div {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface-soft);
    padding: 16px;
  }

  .status-grid strong {
    display: block;
    font-family: var(--font-display);
    font-size: 2.1rem;
    line-height: 1;
  }

  .status-grid span,
  .topic-card span {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .section-heading {
    margin-bottom: 20px;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .topic-card {
    display: grid;
    gap: 14px;
    min-height: 154px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(0, 245, 255, 0.08), rgba(255, 43, 214, 0.05)),
      rgba(11, 16, 32, 0.84);
    padding: 18px;
    color: inherit;
    text-decoration: none;
    transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .topic-card:hover {
    border-color: rgba(255, 43, 214, 0.56);
    box-shadow: var(--pink-glow);
    transform: translateY(-2px);
  }

  .topic-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .topic-card p {
    margin: 0;
    color: var(--muted);
  }

  .topic-groups-section {
    border-top: 1px solid var(--line);
    background:
      linear-gradient(90deg, rgba(255, 43, 214, 0.06), transparent 44%),
      rgba(2, 3, 10, 0.42);
  }

  .topic-groups {
    display: grid;
    gap: 24px;
  }

  .topic-group {
    display: grid;
    gap: 16px;
  }

  .topic-group-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 1px solid var(--line);
    padding-bottom: 14px;
  }

  .topic-group h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 3vw, 2.1rem);
    line-height: 1.1;
  }

  .topic-more {
    border: 1px solid rgba(0, 245, 255, 0.3);
    border-radius: var(--radius);
    background: rgba(0, 245, 255, 0.08);
    padding: 8px 10px;
    color: var(--neon-cyan);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-decoration: none;
  }

  .topic-more:hover {
    border-color: var(--neon-pink);
    color: #ffd8f7;
    box-shadow: var(--pink-glow);
  }

  .article-list {
    display: grid;
    gap: 14px;
  }

  @media (max-width: 900px) {
    .topic-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .topics-copy,
    .topics-status {
      grid-column: auto;
    }
  }

  @media (max-width: 640px) {
    .topic-grid,
    .status-grid {
      grid-template-columns: 1fr;
    }

    .topic-group-head {
      align-items: stretch;
      flex-direction: column;
    }

    .topic-more {
      text-align: center;
    }
  }
</style>
