---
interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<span class="tag-pill">#{tag}</span>

<style>
  .tag-pill {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    border: 1px solid rgba(0, 245, 255, 0.26);
    border-radius: 999px;
    background: rgba(0, 245, 255, 0.08);
    padding: 3px 9px;
    color: var(--neon-cyan);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1;
    white-space: nowrap;
    text-shadow: var(--cyan-glow);
  }
</style>
