---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagPill from "../../components/TagPill.astro";
import { formatDate, sortPostsByDate } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const posts = sortPostsByDate(await getCollection("posts"));
const index = posts.findIndex((item) => item.id === post.id);
const previous = posts[index + 1];
const next = posts[index - 1];
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="section article-page">
    <div class="container">
      <header class="article-header">
        <p class="eyebrow">{formatDate(post.data.date)}</p>
        <h1>{post.data.title}</h1>
        <p class="description">{post.data.description}</p>
        <div class="tags">
          {post.data.tags.map((tag) => <TagPill tag={tag} />)}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>

      <nav class="post-nav" aria-label="文章前后导航">
        {previous ? <a href={`/articles/${previous.id}/`}>上一篇：{previous.data.title}</a> : <span></span>}
        {next ? <a href={`/articles/${next.id}/`}>下一篇：{next.data.title}</a> : <span></span>}
      </nav>

      <section class="comments-reserved" aria-label="评论区预留位置">
        <p class="eyebrow">Comments</p>
        <p>评论区先留白。等这里真的开始热闹，再接入一个合适的评论系统。</p>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    padding-top: 70px;
  }

  .article-header {
    max-width: 820px;
    margin: 0 auto 42px;
    text-align: center;
  }

  .article-header h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 5.6rem);
    line-height: 0.98;
  }

  .description {
    max-width: 640px;
    margin: 20px auto 0;
    color: var(--muted-ink);
    font-size: 1.08rem;
  }

  .tags {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .post-nav {
    max-width: 820px;
    margin: 54px auto 0;
    border-top: 1px solid var(--line);
    padding-top: 22px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .post-nav a:last-child {
    text-align: right;
  }

  .comments-reserved {
    max-width: 820px;
    margin: 42px auto 0;
    border: 1px dashed var(--line);
    border-radius: var(--radius);
    padding: 24px;
    color: var(--muted-ink);
  }

  .comments-reserved p {
    margin: 0;
  }

  @media (max-width: 640px) {
    .post-nav {
      grid-template-columns: 1fr;
    }

    .post-nav a:last-child {
      text-align: left;
    }
  }
</style>
