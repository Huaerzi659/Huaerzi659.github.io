---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagPill from "../../components/TagPill.astro";
import { formatDate, getTagHref, sortPostsByDate } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const posts = sortPostsByDate(await getCollection("posts"));
const index = posts.findIndex((item) => item.id === post.id);
const previous = posts[index + 1];
const next = posts[index - 1];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={`/articles/${post.id}/`}
  image={post.data.image}
  imageAlt={`${post.data.title} 封面图`}
  type="article"
  publishedTime={post.data.date}
  tags={post.data.tags}
>
  <article class="section article-page">
    <div class="container">
      <header class="article-header">
        <p class="terminal-label">record / {formatDate(post.data.date)}</p>
        <h1>{post.data.title}</h1>
        <p class="description">{post.data.description}</p>
        <div class="tags">
          {post.data.tags.map((tag) => <TagPill tag={tag} href={getTagHref(tag)} />)}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>

      <nav class="post-nav" aria-label="文章前后导航">
        {previous ? <a href={`/articles/${previous.id}/`}><span>previous</span>{previous.data.title}</a> : <span></span>}
        {next ? <a href={`/articles/${next.id}/`}><span>next</span>{next.data.title}</a> : <span></span>}
      </nav>

      <section class="comments-reserved" aria-label="评论区预留位置">
        <p class="terminal-label">comments / reserved</p>
        <p>评论区先留白。等这里真的开始热闹，再接入一个合适的评论系统。</p>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    padding-top: 70px;
  }

  .article-header {
    max-width: 820px;
    margin: 0 auto 42px;
  }

  .article-header h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.15rem, 5vw, 4.2rem);
    font-weight: 760;
    line-height: 1.02;
  }

  .description {
    max-width: 680px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .post-nav {
    max-width: 820px;
    margin: 54px auto 0;
    border-top: 1px solid var(--line);
    padding-top: 20px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .post-nav a {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(11, 16, 32, 0.82);
    padding: 14px;
    text-decoration: none;
  }

  :global(:root[data-theme="anime-scroll"]) .post-nav a {
    border-color: rgba(26, 45, 76, 0.24);
    background:
      linear-gradient(135deg, rgba(249, 115, 22, 0.06), transparent 44%),
      var(--surface-quiet);
    box-shadow: 4px 4px 0 rgba(26, 45, 76, 0.08);
    color: var(--ink);
  }

  .post-nav a:hover {
    border-color: var(--neon-pink);
    box-shadow: var(--pink-glow);
  }

  :global(:root[data-theme="anime-scroll"]) .post-nav a:hover {
    border-color: rgba(249, 115, 22, 0.5);
    box-shadow: 5px 5px 0 rgba(15, 139, 179, 0.12);
  }

  .post-nav a:last-child {
    text-align: right;
  }

  .post-nav span {
    display: block;
    color: var(--faint);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .comments-reserved {
    max-width: 820px;
    margin: 36px auto 0;
    border: 1px dashed var(--line-strong);
    border-radius: var(--radius);
    background: rgba(0, 245, 255, 0.06);
    padding: 22px;
    color: var(--muted);
  }

  :global(:root[data-theme="anime-scroll"]) .comments-reserved {
    border-color: rgba(249, 115, 22, 0.38);
    background: rgba(249, 115, 22, 0.08);
    color: var(--copy);
  }

  .comments-reserved p {
    margin: 0;
  }

  @media (max-width: 640px) {
    .post-nav {
      grid-template-columns: 1fr;
    }

    .post-nav a:last-child {
      text-align: left;
    }
  }
</style>
