---
import type { Post } from "../lib/posts";
import { formatDate } from "../lib/posts";
import TagPill from "./TagPill.astro";

interface Props {
  post: Post;
  variant?: "feature" | "compact";
}

const { post, variant = "compact" } = Astro.props;
const href = `/articles/${post.id}/`;
---

<article class:list={["article-card", variant]}>
  <a class="article-link" href={href}>
    <span class="card-sheen" aria-hidden="true"></span>
    <div class="article-meta">
      <span>{formatDate(post.data.date)}</span>
      {variant === "feature" && <span>featured</span>}
    </div>
    <h2>{post.data.title}</h2>
    <p class="article-desc">{post.data.description}</p>
    <div class="article-tags" aria-label="文章标签">
      {post.data.tags.map((tag) => <TagPill tag={tag} />)}
    </div>
  </a>
</article>

<style>
  .article-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line-muted);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(0, 245, 255, 0.032), transparent 46%),
      var(--surface-quiet);
    box-shadow: none;
    transition: background-color var(--motion-short) var(--ease-out), border-color var(--motion-short) var(--ease-out), transform var(--motion-short) var(--ease-out), box-shadow var(--motion-short) var(--ease-out);
  }

  .article-card::before {
    content: "";
    position: absolute;
    top: 0;
    right: 18px;
    left: 18px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 245, 255, 0.28), transparent);
    opacity: 0.7;
    pointer-events: none;
  }

  :global(:root[data-theme="anime-scroll"]) .article-card {
    background:
      linear-gradient(135deg, rgba(249, 115, 22, 0.05), transparent 46%),
      var(--surface-quiet);
  }

  :global(:root[data-theme="minimal"]) .article-card {
    border-color: var(--line-muted);
    background:
      linear-gradient(135deg, var(--glass-blue), transparent 42%),
      linear-gradient(315deg, var(--glass-mint), transparent 48%),
      var(--surface-quiet);
    box-shadow: 0 18px 42px rgba(58, 76, 118, 0.08);
  }

  :global(:root[data-theme="anime-scroll"]) .article-card::before {
    background: linear-gradient(90deg, transparent, rgba(249, 115, 22, 0.34), transparent);
  }

  :global(:root[data-theme="minimal"]) .article-card::before {
    background: linear-gradient(90deg, transparent, rgba(79, 124, 255, 0.38), rgba(238, 95, 134, 0.3), rgba(22, 184, 164, 0.28), transparent);
    opacity: 0.76;
  }

  :global(:root[data-theme="anime-scroll"]) .article-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background: repeating-linear-gradient(
      118deg,
      transparent 0 14px,
      rgba(249, 115, 22, var(--speedline-opacity)) 14px 15px,
      transparent 15px 28px
    );
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--motion-short) var(--ease-out);
  }

  .article-card:hover,
  .article-card:focus-within {
    border-color: rgba(255, 43, 214, 0.52);
    background:
      linear-gradient(135deg, rgba(255, 43, 214, 0.065), transparent 50%),
      rgba(11, 16, 32, 0.88);
    box-shadow: var(--pink-glow);
    transform: translateY(-2px);
  }

  :global(:root[data-theme="anime-scroll"]) .article-card:hover,
  :global(:root[data-theme="anime-scroll"]) .article-card:focus-within {
    border-color: rgba(249, 115, 22, 0.55);
    background:
      linear-gradient(135deg, rgba(249, 115, 22, 0.1), transparent 50%),
      var(--surface);
    box-shadow: 0 14px 34px rgba(57, 42, 22, 0.16);
  }

  :global(:root[data-theme="minimal"]) .article-card:hover,
  :global(:root[data-theme="minimal"]) .article-card:focus-within {
    border-color: rgba(238, 95, 134, 0.34);
    background:
      linear-gradient(135deg, var(--glass-coral), transparent 46%),
      linear-gradient(315deg, var(--glass-lilac), transparent 52%),
      var(--surface);
    box-shadow: var(--pink-glow), var(--shadow);
  }

  :global(:root[data-theme="anime-scroll"]) .article-card:hover::after,
  :global(:root[data-theme="anime-scroll"]) .article-card:focus-within::after {
    opacity: 1;
  }

  .article-link {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: 100%;
    gap: 12px;
    padding: 20px;
    color: inherit;
    cursor: pointer;
    text-decoration: none;
  }

  .article-link > :not(.card-sheen) {
    position: relative;
    z-index: 1;
  }

  .card-sheen {
    position: absolute;
    inset: -30% auto -30% -24%;
    z-index: 0;
    width: 34%;
    background: linear-gradient(90deg, transparent, rgba(0, 245, 255, 0.09), rgba(255, 43, 214, 0.13), transparent);
    opacity: 0;
    pointer-events: none;
    transform: translateX(-140%) skewX(-18deg);
  }

  :global(:root[data-theme="anime-scroll"]) .card-sheen {
    display: none;
    animation: none;
    opacity: 0;
  }

  :global(:root[data-theme="minimal"]) .card-sheen {
    display: none;
    animation: none;
    opacity: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .article-card:hover .card-sheen,
    .article-card:focus-within .card-sheen {
      animation: sheen-pass 620ms var(--ease-out);
      opacity: 1;
    }

    :global(:root[data-theme="anime-scroll"]) .article-card:hover .card-sheen,
    :global(:root[data-theme="anime-scroll"]) .article-card:focus-within .card-sheen {
      animation: none;
      opacity: 0;
    }

    :global(:root[data-theme="minimal"]) .article-card:hover .card-sheen,
    :global(:root[data-theme="minimal"]) .article-card:focus-within .card-sheen {
      animation: none;
      opacity: 0;
    }
  }

  .feature {
    background:
      linear-gradient(135deg, rgba(0, 245, 255, 0.07), rgba(255, 43, 214, 0.05)),
      var(--surface-muted);
  }

  :global(:root[data-theme="minimal"]) .feature {
    background:
      linear-gradient(135deg, var(--glass-blue), var(--glass-coral)),
      linear-gradient(315deg, var(--glass-mint), transparent 58%),
      var(--surface-muted);
  }

  .feature .article-link {
    padding: 24px;
  }

  .article-meta {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    color: var(--faint);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.7rem);
    font-weight: 720;
    line-height: 1.15;
    letter-spacing: 0;
    text-shadow: 0 0 18px rgba(0, 245, 255, 0.12);
  }

  :global(:root[data-theme="anime-scroll"]) h2 {
    text-shadow: none;
  }

  :global(:root[data-theme="minimal"]) h2 {
    text-shadow: none;
  }

  .feature h2 {
    font-size: clamp(1.45rem, 3vw, 2.15rem);
  }

  .article-desc {
    margin: 0;
    color: var(--copy);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
</style>
