---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import TagPill from "../components/TagPill.astro";
import { getAllTags, getFeaturedPosts, getTagHref, sortPostsByDate } from "../lib/posts";

const posts = sortPostsByDate(await getCollection("posts"));
const featured = getFeaturedPosts(posts);
const recent = posts.slice(0, 3);
const tags = getAllTags(posts);
---

<BaseLayout description="Waltz 的个人博客：技术、经验、感想与灵感。">
  <section class="section workbench-hero">
    <div class="container workbench-grid">
      <div class="identity-panel">
        <span class="hero-hud" aria-hidden="true"></span>
        <span class="hero-scanline" aria-hidden="true"></span>
        <p class="terminal-label">waltz.workspace / online</p>
        <h1 class="display-title">Waltz,<br />Then Think</h1>
        <p class="hero-copy">
          一个用来存放技术、经验和想法的个人工作台。写代码，也写那些还没完全成型的念头。
        </p>
        <div class="button-row">
          <a class="button" href="/articles/">读文章</a>
          <a class="button secondary" href="/about/">关于我</a>
        </div>
        <p class="stat-line" aria-label="当前状态">
          <span>now: building</span>
          <span>writing</span>
          <span>debugging</span>
        </p>
      </div>

      <aside class="desk-panel surface" aria-label="思考工作台摘要">
        <div class="panel-head">
          <p class="terminal-label">thinking desk</p>
          <span class="status-dot status-pulse">live</span>
        </div>
        <div class="desk-stats">
          <div>
            <strong>{posts.length}</strong>
            <span>articles</span>
          </div>
          <div>
            <strong>{tags.length}</strong>
            <span>topics</span>
          </div>
        </div>
        <div class="desk-list">
          <p class="desk-title">最近写下</p>
          {recent.map((post) => (
            <a href={`/articles/${post.id}/`}>
              <span>{post.data.title}</span>
              <small>{post.data.tags[0]}</small>
            </a>
          ))}
        </div>
        <div class="thinking-note">
          <p class="terminal-label">current thought</p>
          <p>把问题拆小，把想法写下，再慢慢把它们变成自己的方法。</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container section-grid">
      <div class="section-intro">
        <p class="terminal-label">recent log</p>
        <h2 class="section-title">最近写下</h2>
        <p>这里不是最终答案库，更像持续更新的思考记录。</p>
      </div>
      <div class="record-list">
        {recent.map((post) => <ArticleCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="section focus-section">
    <div class="container">
      <div class="section-heading">
        <p class="terminal-label">pinned thinking</p>
        <h2 class="section-title">精选思考</h2>
      </div>
      <div class="featured-grid">
        {featured.map((post) => <ArticleCard post={post} variant="feature" />)}
      </div>
    </div>
  </section>

  <section class="section topic-section">
    <div class="container topic-panel">
      <div>
        <p class="terminal-label">topic index</p>
        <h2 class="section-title">主题索引</h2>
        <p>技术、经验、感想和灵感会暂时放在这些入口下面，之后再慢慢长出更清晰的分类。</p>
      </div>
      <div class="tag-board">
        {tags.map((tag) => <TagPill tag={tag} href={getTagHref(tag)} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .workbench-hero {
    padding-top: 78px;
    border-bottom: 1px solid var(--line);
  }

  .identity-panel {
    grid-column: span 7;
    position: relative;
    isolation: isolate;
    min-height: 520px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 22px;
    overflow: hidden;
  }

  .identity-panel > :not(.hero-hud):not(.hero-scanline) {
    position: relative;
    z-index: 1;
  }

  .hero-hud,
  .hero-scanline {
    position: absolute;
    pointer-events: none;
  }

  .hero-hud {
    inset: 18px -10px 18px 0;
    z-index: 0;
    border-left: 1px solid rgba(0, 245, 255, 0.32);
    background:
      linear-gradient(90deg, rgba(0, 245, 255, 0.12), transparent 28%),
      linear-gradient(180deg, rgba(255, 43, 214, 0.08), transparent 34%);
    mask-image:
      linear-gradient(90deg, #000 0 1px, transparent 1px),
      linear-gradient(180deg, #000 0 1px, transparent 1px);
    mask-size: 34px 34px;
    opacity: 0.54;
  }

  .hero-scanline {
    left: 0;
    right: 12%;
    top: 28%;
    z-index: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 245, 255, 0.74), rgba(255, 43, 214, 0.48), transparent);
    box-shadow: 0 0 18px rgba(0, 245, 255, 0.28);
    transform: translateX(-120%);
  }

  .hero-copy {
    max-width: 620px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.28rem);
    line-height: 1.75;
  }

  .desk-panel {
    grid-column: 8 / span 5;
    align-self: center;
    padding: 22px;
  }

  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .status-dot {
    border: 1px solid rgba(34, 197, 94, 0.36);
    border-radius: 999px;
    background: var(--mint-soft);
    padding: 4px 9px;
    color: var(--mint);
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }

  @keyframes hero-scanline-pass {
    0% {
      transform: translateX(-120%);
      opacity: 0;
    }

    18%,
    62% {
      opacity: 0.72;
    }

    100% {
      transform: translateX(120%);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-scanline {
      animation: hero-scanline-pass 7s var(--ease-out) 900ms infinite;
    }

    .status-pulse {
      animation: signal-pulse 2.8s var(--ease-out) infinite;
    }
  }

  .desk-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin: 12px 0 18px;
  }

  .desk-stats div {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(0, 245, 255, 0.08), transparent),
      var(--surface-soft);
    padding: 16px;
  }

  .desk-stats strong {
    display: block;
    font-family: var(--font-display);
    font-size: 2.1rem;
    line-height: 1;
  }

  .desk-stats span {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .desk-list {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 14px 0;
  }

  .desk-title {
    margin: 0 0 8px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .desk-list a {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    border-radius: var(--radius);
    padding: 9px 0;
    text-decoration: none;
  }

  .desk-list a + a {
    border-top: 1px solid rgba(0, 245, 255, 0.16);
  }

  .desk-list span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .desk-list small {
    color: var(--faint);
    font-family: var(--font-mono);
  }

  .thinking-note {
    margin-top: 18px;
    border: 1px solid rgba(250, 204, 21, 0.28);
    border-radius: var(--radius);
    background: var(--signal-soft);
    padding: 16px;
    box-shadow: 0 0 22px rgba(250, 204, 21, 0.08);
  }

  .thinking-note p:last-child {
    margin: 0;
    color: #fde68a;
  }

  .section-grid {
    display: grid;
    grid-template-columns: minmax(220px, 0.38fr) minmax(0, 1fr);
    gap: 24px;
  }

  .section-intro {
    position: sticky;
    top: 88px;
    align-self: start;
  }

  .section-intro p:last-child,
  .topic-panel p {
    color: var(--muted);
  }

  .record-list {
    display: grid;
    gap: 14px;
  }

  .focus-section {
    background:
      linear-gradient(90deg, rgba(255, 43, 214, 0.08), transparent 45%),
      rgba(2, 3, 10, 0.56);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .section-heading {
    margin-bottom: 20px;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .topic-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(0, 245, 255, 0.08), rgba(255, 43, 214, 0.06)),
      rgba(11, 16, 32, 0.86);
    box-shadow: var(--shadow);
    padding: 26px;
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr);
    gap: 22px;
  }

  .tag-board {
    align-self: end;
    display: flex;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 10px;
  }

  @media (max-width: 900px) {
    .identity-panel,
    .desk-panel {
      grid-column: auto;
      min-height: auto;
    }

    .workbench-hero {
      padding-top: 48px;
    }

    .featured-grid,
    .section-grid,
    .topic-panel {
      grid-template-columns: 1fr;
    }

    .section-intro {
      position: static;
    }

    .tag-board {
      justify-content: flex-start;
    }
  }

  @media (max-width: 560px) {
    .desk-list a {
      grid-template-columns: 1fr;
      gap: 2px;
    }
  }
</style>
