---
import type { Post } from "../lib/posts";
import { formatDate } from "../lib/posts";
import TagPill from "./TagPill.astro";

interface Props {
  post: Post;
  variant?: "feature" | "compact";
}

const { post, variant = "compact" } = Astro.props;
const href = `/articles/${post.id}/`;
---

<article class:list={["article-card", variant]}>
  <a class="article-link" href={href}>
    <span class="card-sheen" aria-hidden="true"></span>
    <div class="article-meta">
      <span>{formatDate(post.data.date)}</span>
      {variant === "feature" && <span>featured</span>}
    </div>
    <h2>{post.data.title}</h2>
    <p class="article-desc">{post.data.description}</p>
    <div class="article-tags" aria-label="文章标签">
      {post.data.tags.map((tag) => <TagPill tag={tag} />)}
    </div>
  </a>
</article>

<style>
  .article-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(0, 245, 255, 0.06), transparent 46%),
      rgba(11, 16, 32, 0.82);
    box-shadow: inset 0 0 0 1px rgba(255, 43, 214, 0.04);
    transition: background-color var(--motion-short) var(--ease-out), border-color var(--motion-short) var(--ease-out), transform var(--motion-short) var(--ease-out), box-shadow var(--motion-short) var(--ease-out);
  }

  .article-card:hover,
  .article-card:focus-within {
    border-color: rgba(255, 43, 214, 0.52);
    background:
      linear-gradient(135deg, rgba(255, 43, 214, 0.08), transparent 50%),
      rgba(11, 16, 32, 0.94);
    box-shadow: var(--pink-glow);
    transform: translateY(-2px);
  }

  .article-link {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: 100%;
    gap: 12px;
    padding: 20px;
    color: inherit;
    cursor: pointer;
    text-decoration: none;
  }

  .article-link > :not(.card-sheen) {
    position: relative;
    z-index: 1;
  }

  .card-sheen {
    position: absolute;
    inset: -30% auto -30% -24%;
    z-index: 0;
    width: 34%;
    background: linear-gradient(90deg, transparent, rgba(0, 245, 255, 0.12), rgba(255, 43, 214, 0.16), transparent);
    opacity: 0;
    pointer-events: none;
    transform: translateX(-140%) skewX(-18deg);
  }

  @media (prefers-reduced-motion: no-preference) {
    .article-card:hover .card-sheen,
    .article-card:focus-within .card-sheen {
      animation: sheen-pass 620ms var(--ease-out);
      opacity: 1;
    }
  }

  .feature {
    background:
      linear-gradient(135deg, rgba(0, 245, 255, 0.12), rgba(255, 43, 214, 0.08)),
      rgba(11, 16, 32, 0.88);
  }

  .feature .article-link {
    padding: 24px;
  }

  .article-meta {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    color: var(--neon-cyan);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.7rem);
    font-weight: 720;
    line-height: 1.15;
    letter-spacing: 0;
    text-shadow: 0 0 18px rgba(0, 245, 255, 0.12);
  }

  .feature h2 {
    font-size: clamp(1.45rem, 3vw, 2.15rem);
  }

  .article-desc {
    margin: 0;
    color: var(--muted);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
</style>
