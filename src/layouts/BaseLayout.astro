---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Waltz, Then Think",
  description = "Waltz 的个人博客：技术、经验、感想与灵感。",
} = Astro.props;

const pageTitle = title === "Waltz, Then Think" ? title : `${title} | Waltz, Then Think`;
---

<!doctype html>
<html lang="zh-CN" data-theme="cyber">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#05060f" />
    <script is:inline>
      (() => {
        const storageKey = "waltz-theme";
        const themes = new Set(["cyber", "anime-scroll"]);
        const colors = {
          cyber: "#05060f",
          "anime-scroll": "#f7efe0",
        };

        try {
          const stored = localStorage.getItem(storageKey);
          const theme = themes.has(stored) ? stored : "cyber";
          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme === "anime-scroll" ? "light" : "dark";
          document.querySelector('meta[name="theme-color"]')?.setAttribute("content", colors[theme]);
        } catch {
          document.documentElement.dataset.theme = "cyber";
        }
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Waltz, Then Think RSS"
      href={new URL("rss.xml", Astro.site)}
    />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <BackToTop />
  </body>
</html>
