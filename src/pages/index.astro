---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import TagPill from "../components/TagPill.astro";
import { getAllTags, getFeaturedPosts, getTagHref, sortPostsByDate } from "../lib/posts";

const posts = sortPostsByDate(await getCollection("posts"));
const featured = getFeaturedPosts(posts);
const recent = posts.slice(0, 3);
const tags = getAllTags(posts);
---

<BaseLayout description="Waltz 的个人博客：技术、经验、感想与灵感。">
  <section class="section workbench-hero">
    <div class="container workbench-grid">
      <div class="identity-panel">
        <span class="hero-hud hero-noise" aria-hidden="true"></span>
        <span class="hero-scanline" aria-hidden="true"></span>
        <span class="anime-mascot" aria-label="原创看板人物" role="img">
          <span class="mascot-scroll" aria-hidden="true"></span>
          <span class="mascot-figure" aria-hidden="true"></span>
        </span>
        <p class="terminal-label">waltz.workspace / online</p>
        <h1 class="display-title">Waltz,<br />Then Think</h1>
        <p class="hero-copy">
          一个用来存放技术、经验和想法的个人工作台。写代码，也写那些还没完全成型的念头。
        </p>
        <div class="button-row">
          <a class="button" href="/articles/">读文章</a>
          <a class="button secondary" href="/about/">关于我</a>
        </div>
        <p class="stat-line" aria-label="当前状态">
          <span>now: building</span>
          <span>writing</span>
          <span>debugging</span>
        </p>
      </div>

      <aside class="desk-panel surface" aria-label="思考工作台摘要">
        <div class="panel-head">
          <p class="terminal-label">thinking desk</p>
          <span class="status-dot status-pulse">live</span>
        </div>
        <div class="desk-stats">
          <div>
            <strong>{posts.length}</strong>
            <span>articles</span>
          </div>
          <div>
            <strong>{tags.length}</strong>
            <span>topics</span>
          </div>
        </div>
        <div class="desk-list">
          <p class="desk-title">最近写下</p>
          {recent.map((post) => (
            <a href={`/articles/${post.id}/`}>
              <span>{post.data.title}</span>
              <small>{post.data.tags[0]}</small>
            </a>
          ))}
        </div>
        <div class="thinking-note">
          <p class="terminal-label">current thought</p>
          <p>把问题拆小，把想法写下，再慢慢把它们变成自己的方法。</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container section-grid">
      <div class="section-intro">
        <p class="terminal-label">recent log</p>
        <h2 class="section-title">最近写下</h2>
        <p>这里不是最终答案库，更像持续更新的思考记录。</p>
      </div>
      <div class="record-list">
        {recent.map((post) => <ArticleCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="section focus-section">
    <div class="container">
      <div class="section-heading">
        <p class="terminal-label">pinned thinking</p>
        <h2 class="section-title">精选思考</h2>
      </div>
      <div class="featured-grid">
        {featured.map((post) => <ArticleCard post={post} variant="feature" />)}
      </div>
    </div>
  </section>

  <section class="section topic-section">
    <div class="container topic-panel">
      <div>
        <p class="terminal-label">topic index</p>
        <h2 class="section-title">主题索引</h2>
        <p>技术、经验、感想和灵感会暂时放在这些入口下面，之后再慢慢长出更清晰的分类。</p>
      </div>
      <div class="tag-board">
        {tags.map((tag) => <TagPill tag={tag} href={getTagHref(tag)} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .workbench-hero {
    padding-top: 78px;
    border-bottom: 1px solid var(--line);
  }

  .identity-panel {
    grid-column: span 8;
    position: relative;
    isolation: isolate;
    min-height: 500px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 22px;
    overflow: hidden;
  }

  .identity-panel > :not(.hero-hud):not(.hero-scanline):not(.anime-mascot) {
    position: relative;
    z-index: 1;
  }

  .hero-hud,
  .hero-scanline {
    position: absolute;
    pointer-events: none;
  }

  .hero-hud {
    inset: 26px -10px 24px 0;
    z-index: 0;
    border-left: 1px solid rgba(0, 245, 255, 0.2);
    background:
      linear-gradient(90deg, rgba(0, 245, 255, 0.07), transparent 28%),
      linear-gradient(180deg, rgba(255, 43, 214, 0.045), transparent 34%);
    mask-image:
      linear-gradient(90deg, #000 0 1px, transparent 1px),
      linear-gradient(180deg, #000 0 1px, transparent 1px);
    mask-size: 34px 34px;
    opacity: 0.36;
  }

  .hero-scanline {
    left: 0;
    right: 12%;
    top: 28%;
    z-index: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 245, 255, 0.48), rgba(255, 43, 214, 0.28), transparent);
    box-shadow: 0 0 14px rgba(0, 245, 255, 0.16);
    transform: translateX(-120%);
  }

  .hero-copy {
    max-width: 620px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.28rem);
    line-height: 1.75;
  }

  .anime-mascot {
    position: absolute;
    right: 2%;
    bottom: 18px;
    z-index: 0;
    display: none;
    width: min(240px, 34vw);
    aspect-ratio: 3 / 4;
    opacity: 0.26;
    pointer-events: none;
  }

  :global(:root[data-theme="anime-scroll"]) .anime-mascot {
    display: block;
  }

  .mascot-scroll,
  .mascot-figure {
    position: absolute;
    inset: 0;
  }

  .mascot-scroll {
    border: 2px solid rgba(26, 45, 76, 0.42);
    border-radius: 42% 42% 10px 10px;
    background:
      radial-gradient(circle at 28% 14%, rgba(249, 115, 22, 0.2) 0 7px, transparent 8px),
      linear-gradient(135deg, rgba(255, 250, 240, 0.74), rgba(243, 230, 208, 0.54));
    box-shadow: 0 18px 40px rgba(57, 42, 22, 0.16);
    transform: rotate(-4deg);
  }

  .mascot-scroll::before,
  .mascot-scroll::after {
    content: "";
    position: absolute;
    left: 14%;
    right: 14%;
    height: 2px;
    border-radius: 999px;
    background: rgba(26, 45, 76, 0.28);
  }

  .mascot-scroll::before {
    top: 18%;
  }

  .mascot-scroll::after {
    bottom: 16%;
  }

  .mascot-figure {
    transform: translateY(7%) rotate(2deg);
  }

  .mascot-figure::before {
    content: "";
    position: absolute;
    left: 28%;
    top: 12%;
    width: 44%;
    aspect-ratio: 1;
    border: 3px solid rgba(22, 32, 47, 0.62);
    border-radius: 50%;
    background:
      linear-gradient(135deg, rgba(255, 250, 240, 0.92), rgba(249, 115, 22, 0.18)),
      var(--surface);
    box-shadow: 0 8px 0 rgba(15, 139, 179, 0.18);
  }

  .mascot-figure::after {
    content: "";
    position: absolute;
    left: 22%;
    right: 16%;
    bottom: 14%;
    height: 48%;
    border: 3px solid rgba(22, 32, 47, 0.58);
    border-radius: 44% 44% 12% 12%;
    background:
      linear-gradient(130deg, rgba(15, 139, 179, 0.56), transparent 38%),
      linear-gradient(42deg, rgba(249, 115, 22, 0.52), transparent 48%),
      rgba(255, 250, 240, 0.9);
    clip-path: polygon(14% 0, 86% 0, 100% 100%, 0 100%);
  }

  .desk-panel {
    grid-column: 9 / span 4;
    align-self: center;
    background:
      linear-gradient(145deg, rgba(0, 245, 255, 0.05), transparent 42%),
      var(--surface-quiet);
    box-shadow: var(--glow-soft);
    padding: 22px;
  }

  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .status-dot {
    border: 1px solid rgba(0, 245, 255, 0.26);
    border-radius: 999px;
    background: rgba(0, 245, 255, 0.075);
    padding: 4px 9px;
    color: var(--accent-ink);
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }

  :global(:root[data-theme="minimal"]) .status-dot {
    border-color: rgba(22, 184, 164, 0.3);
    background: linear-gradient(135deg, var(--glass-mint), rgba(255, 255, 255, 0.68));
    color: #117c71;
  }

  @keyframes hero-scanline-pass {
    0% {
      transform: translateX(-120%);
      opacity: 0;
    }

    18%,
    62% {
      opacity: 0.72;
    }

    100% {
      transform: translateX(120%);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-scanline {
      animation: hero-scanline-pass 7s var(--ease-out) 900ms infinite;
    }

    .status-pulse {
      animation: signal-pulse 2.8s var(--ease-out) infinite;
    }
  }

  .desk-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin: 12px 0 18px;
  }

  .desk-stats div {
    border: 1px solid var(--line-muted);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(0, 245, 255, 0.045), transparent),
      var(--surface-muted);
    padding: 16px;
  }

  :global(:root[data-theme="minimal"]) .desk-stats div {
    background:
      linear-gradient(135deg, var(--glass-blue), transparent 58%),
      linear-gradient(315deg, var(--glass-mint), transparent 62%),
      var(--surface-muted);
  }

  .desk-stats strong {
    display: block;
    font-family: var(--font-display);
    font-size: 2.1rem;
    line-height: 1;
  }

  .desk-stats span {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .desk-list {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 14px 0;
  }

  .desk-title {
    margin: 0 0 8px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .desk-list a {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    border-radius: var(--radius);
    padding: 9px 0;
    text-decoration: none;
  }

  .desk-list a + a {
    border-top: 1px solid rgba(0, 245, 255, 0.16);
  }

  .desk-list span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .desk-list small {
    color: var(--faint);
    font-family: var(--font-mono);
  }

  .thinking-note {
    margin-top: 18px;
    border: 1px solid rgba(255, 43, 214, 0.18);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(255, 43, 214, 0.055), transparent 52%),
      rgba(0, 245, 255, 0.045);
    padding: 16px;
    box-shadow: none;
  }

  :global(:root[data-theme="minimal"]) .thinking-note {
    border-color: rgba(238, 95, 134, 0.24);
    background:
      linear-gradient(135deg, var(--glass-coral), transparent 52%),
      linear-gradient(315deg, var(--glass-lilac), transparent 58%),
      rgba(255, 255, 255, 0.54);
  }

  .thinking-note p:last-child {
    margin: 0;
    color: var(--copy);
  }

  .section-grid {
    display: grid;
    grid-template-columns: minmax(220px, 0.38fr) minmax(0, 1fr);
    gap: 24px;
  }

  .section-intro {
    position: sticky;
    top: 88px;
    align-self: start;
  }

  .section-intro p:last-child,
  .topic-panel p {
    color: var(--muted);
  }

  .record-list {
    display: grid;
    gap: 14px;
  }

  .focus-section {
    background:
      linear-gradient(90deg, rgba(255, 43, 214, 0.045), transparent 45%),
      rgba(2, 3, 10, 0.56);
    border-top: 1px solid var(--line-muted);
    border-bottom: 1px solid var(--line-muted);
  }

  :global(:root[data-theme="anime-scroll"]) .focus-section {
    background:
      linear-gradient(90deg, rgba(249, 115, 22, 0.08), transparent 45%),
      rgba(255, 250, 240, 0.52);
  }

  :global(:root[data-theme="minimal"]) .focus-section {
    background:
      linear-gradient(90deg, rgba(238, 95, 134, 0.09), transparent 36%),
      linear-gradient(270deg, rgba(22, 184, 164, 0.08), transparent 42%),
      rgba(255, 255, 255, 0.54);
  }

  .section-heading {
    margin-bottom: 20px;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .topic-panel {
    border: 1px solid var(--line-muted);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(0, 245, 255, 0.045), rgba(255, 43, 214, 0.035)),
      var(--surface-quiet);
    box-shadow: var(--glow-soft);
    padding: 26px;
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr);
    gap: 22px;
  }

  :global(:root[data-theme="anime-scroll"]) .topic-panel,
  :global(:root[data-theme="anime-scroll"]) .desk-panel {
    background:
      linear-gradient(135deg, rgba(249, 115, 22, 0.08), rgba(15, 139, 179, 0.055)),
      var(--surface-quiet);
  }

  :global(:root[data-theme="minimal"]) .topic-panel,
  :global(:root[data-theme="minimal"]) .desk-panel {
    border-color: var(--line-muted);
    background:
      linear-gradient(135deg, var(--glass-blue), transparent 46%),
      linear-gradient(315deg, var(--glass-coral), transparent 52%),
      var(--surface-quiet);
    box-shadow: var(--shadow);
  }

  :global(:root[data-theme="anime-scroll"]) .hero-hud {
    border-left-color: rgba(26, 45, 76, 0.2);
    background:
      linear-gradient(90deg, rgba(249, 115, 22, 0.1), transparent 28%),
      linear-gradient(180deg, rgba(15, 139, 179, 0.07), transparent 34%);
    opacity: 0.22;
  }

  :global(:root[data-theme="minimal"]) .hero-hud {
    border-left-color: rgba(79, 124, 255, 0.16);
    background:
      linear-gradient(90deg, rgba(79, 124, 255, 0.09), transparent 28%),
      linear-gradient(180deg, rgba(238, 95, 134, 0.07), transparent 34%);
    opacity: 0.18;
  }

  :global(:root[data-theme="anime-scroll"]) .hero-scanline {
    background: linear-gradient(90deg, transparent, rgba(249, 115, 22, 0.48), rgba(15, 139, 179, 0.28), transparent);
    box-shadow: 0 0 14px rgba(249, 115, 22, 0.12);
  }

  :global(:root[data-theme="minimal"]) .hero-scanline {
    display: none;
  }

  .tag-board {
    align-self: end;
    display: flex;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 10px;
  }

  @media (max-width: 900px) {
    .identity-panel,
    .desk-panel {
      grid-column: auto;
      min-height: auto;
    }

    .workbench-hero {
      padding-top: 48px;
    }

    .featured-grid,
    .section-grid,
    .topic-panel {
      grid-template-columns: 1fr;
    }

    .section-intro {
      position: static;
    }

    .tag-board {
      justify-content: flex-start;
    }
  }

  @media (max-width: 560px) {
    .anime-mascot {
      right: 4px;
      bottom: 4px;
      width: 86px;
      opacity: 0.2;
    }

    .desk-list a {
      grid-template-columns: 1fr;
      gap: 2px;
    }
  }
</style>
