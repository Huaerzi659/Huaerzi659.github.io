---
import type { Post } from "../lib/posts";
import { formatDate } from "../lib/posts";
import TagPill from "./TagPill.astro";

interface Props {
  post: Post;
  variant?: "feature" | "compact";
}

const { post, variant = "compact" } = Astro.props;
const href = `/articles/${post.id}/`;
---

<article class:list={["article-card", variant]}>
  <a class="article-link" href={href}>
    <div class="article-meta">
      <span>{formatDate(post.data.date)}</span>
      {variant === "feature" && <span>featured</span>}
    </div>
    <h2>{post.data.title}</h2>
    <p class="article-desc">{post.data.description}</p>
    <div class="article-tags" aria-label="文章标签">
      {post.data.tags.map((tag) => <TagPill tag={tag} />)}
    </div>
  </a>
</article>

<style>
  .article-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.72);
    transition: background-color 180ms ease, border-color 180ms ease, transform 180ms ease;
  }

  .article-card:hover {
    border-color: rgba(37, 99, 235, 0.38);
    background: var(--surface);
    transform: translateY(-2px);
  }

  .article-link {
    display: grid;
    min-height: 100%;
    gap: 12px;
    padding: 20px;
    color: inherit;
    text-decoration: none;
  }

  .feature {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(219, 234, 254, 0.5));
  }

  .feature .article-link {
    padding: 24px;
  }

  .article-meta {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    color: var(--faint);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.7rem);
    font-weight: 720;
    line-height: 1.15;
    letter-spacing: 0;
  }

  .feature h2 {
    font-size: clamp(1.45rem, 3vw, 2.15rem);
  }

  .article-desc {
    margin: 0;
    color: var(--muted);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
</style>
