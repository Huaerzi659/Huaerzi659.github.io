---
interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<span class="tag-pill">#{tag}</span>

<style>
  .tag-pill {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(237, 243, 248, 0.72);
    padding: 3px 9px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1;
    white-space: nowrap;
  }
</style>
