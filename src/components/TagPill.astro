---
interface Props {
  tag: string;
  href?: string;
  count?: number;
}

const { tag, href, count } = Astro.props;
---

{
  href ? (
    <a class="tag-pill tag-link" href={href} aria-label={`查看 ${tag} 主题`}>
      <span class="tag-sheen" aria-hidden="true"></span>
      <span>#{tag}</span>
      {count !== undefined && <span class="tag-count">{count}</span>}
    </a>
  ) : (
    <span class="tag-pill">
      <span>#{tag}</span>
      {count !== undefined && <span class="tag-count">{count}</span>}
    </span>
  )
}

<style>
  .tag-pill {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 28px;
    border: 1px solid rgba(0, 245, 255, 0.26);
    border-radius: 999px;
    background: rgba(0, 245, 255, 0.08);
    padding: 3px 9px;
    color: var(--neon-cyan);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1;
    white-space: nowrap;
    text-shadow: var(--cyan-glow);
  }

  :global(:root[data-theme="anime-scroll"]) .tag-pill {
    border-color: rgba(249, 115, 22, 0.34);
    border-radius: 6px;
    background: var(--stamp-bg);
    color: #9a3412;
    text-shadow: none;
  }

  .tag-link {
    cursor: pointer;
    text-decoration: none;
    transition: background-color var(--motion-short) var(--ease-out), border-color var(--motion-short) var(--ease-out), color var(--motion-short) var(--ease-out), box-shadow var(--motion-short) var(--ease-out);
  }

  .tag-link > :not(.tag-sheen) {
    position: relative;
    z-index: 1;
  }

  .tag-link:hover,
  .tag-link:focus-visible {
    border-color: rgba(255, 43, 214, 0.58);
    background: rgba(255, 43, 214, 0.1);
    box-shadow: var(--pink-glow);
    color: #ffd8f7;
  }

  :global(:root[data-theme="anime-scroll"]) .tag-link:hover,
  :global(:root[data-theme="anime-scroll"]) .tag-link:focus-visible {
    border-color: rgba(15, 139, 179, 0.56);
    background: rgba(15, 139, 179, 0.1);
    box-shadow: 0 10px 22px rgba(15, 139, 179, 0.14);
    color: #0f5f8a;
  }

  .tag-sheen {
    position: absolute;
    inset: -40% auto -40% -34%;
    z-index: 0;
    width: 42%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    opacity: 0;
    pointer-events: none;
    transform: translateX(-140%) skewX(-18deg);
  }

  @media (prefers-reduced-motion: no-preference) {
    .tag-link:hover .tag-sheen,
    .tag-link:focus-visible .tag-sheen {
      animation: sheen-pass 520ms var(--ease-out);
      opacity: 1;
    }
  }

  .tag-count {
    border-left: 1px solid rgba(0, 245, 255, 0.24);
    padding-left: 6px;
    color: var(--accent-ink);
  }

  :global(:root[data-theme="anime-scroll"]) .tag-count {
    border-left-color: rgba(249, 115, 22, 0.26);
    color: #0f5f8a;
  }
</style>
