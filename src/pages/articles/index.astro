---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import TagPill from "../../components/TagPill.astro";
import { getAllTags, sortPostsByDate } from "../../lib/posts";

const posts = sortPostsByDate(await getCollection("posts"));
const tags = getAllTags(posts);
---

<BaseLayout title="文章" description="Waltz 的文章列表：技术、经验、感想与灵感。">
  <section class="section archive-hero">
    <div class="container workbench-grid">
      <div class="archive-title">
        <p class="terminal-label">archive / all records</p>
        <h1 class="section-title">文章</h1>
        <p>这里收纳完整记录。技术、经验、感想和灵感不必被切得太整齐，它们都会先在这里留下痕迹。</p>
      </div>
      <div class="archive-panel surface">
        <p class="terminal-label">topics</p>
        <div class="article-tags">
          {tags.map((tag) => <TagPill tag={tag} />)}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container article-list">
      {posts.map((post) => <ArticleCard post={post} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .archive-hero {
    border-bottom: 1px solid var(--line);
  }

  .archive-title {
    grid-column: span 7;
  }

  .archive-title p:last-child {
    max-width: 620px;
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .archive-panel {
    grid-column: 8 / span 5;
    align-self: end;
    padding: 20px;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .article-list {
    display: grid;
    gap: 14px;
  }

  @media (max-width: 760px) {
    .archive-title,
    .archive-panel {
      grid-column: auto;
    }
  }
</style>
