---
import type { Post } from "../lib/posts";
import { formatDate } from "../lib/posts";
import TagPill from "./TagPill.astro";

interface Props {
  post: Post;
  variant?: "feature" | "compact";
}

const { post, variant = "compact" } = Astro.props;
const href = `/articles/${post.id}/`;
---

<article class:list={["article-card", variant]}>
  <a class="article-link" href={href}>
    <p class="article-date">{formatDate(post.data.date)}</p>
    <h2>{post.data.title}</h2>
    <p class="article-desc">{post.data.description}</p>
    <div class="article-tags" aria-label="文章标签">
      {post.data.tags.map((tag) => <TagPill tag={tag} />)}
    </div>
  </a>
</article>

<style>
  .article-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.48);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .article-card:hover {
    border-color: rgba(15, 111, 117, 0.35);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .article-link {
    display: grid;
    min-height: 100%;
    gap: 12px;
    padding: 22px;
    text-decoration: none;
  }

  .feature .article-link {
    padding: 30px;
  }

  .article-date {
    margin: 0;
    color: var(--muted-ink);
    font-size: 0.86rem;
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 3vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .compact h2 {
    font-size: clamp(1.3rem, 2vw, 1.8rem);
  }

  .article-desc {
    margin: 0;
    color: var(--muted-ink);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 6px;
  }
</style>
